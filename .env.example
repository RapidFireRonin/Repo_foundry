# Repo Foundry local settings. Copy to .env locally; never commit .env.
REPO_FOUNDRY_DB=./data/repo_foundry.sqlite3
REPO_FOUNDRY_AUDIT_LOG=./logs/audit.jsonl
REPO_FOUNDRY_ARTIFACT_DIR=./artifacts
REPO_FOUNDRY_DEFAULT_PRIVATE=true
REPO_FOUNDRY_DRY_RUN=true

# GitHub
GITHUB_OWNER=RapidFireRonin
GH_TOKEN=
REPO_FOUNDRY_GH_TOKEN=
GITHUB_APP_SLUG=

# Local runtime
AGENT_RUNTIME_ROOT=C:\AgentRuntime
SELF_HOSTED_RUNNER_LABELS=repo-foundry,windows,local
